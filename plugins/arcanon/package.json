{
  "name": "@arcanon/plugin",
  "version": "0.1.4",
  "description": "Arcanon — cross-repo service dependency scanner for Claude Code",
  "license": "AGPL-3.0-only",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Arcanon-hub/arcanon"
  },
  "homepage": "https://arcanon.dev",
  "keywords": [
    "claude-code",
    "plugin",
    "arcanon",
    "service-graph",
    "cross-repo",
    "dependency-mapping"
  ],
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/static": "^9.1.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.9.0",
    "chromadb": "^3.3.3",
    "fastify": "^5.8.5",
    "js-yaml": "^4.1.0",
    "picomatch": "^4.0.4",
    "zod": "^3.25.0"
  },
  "optionalDependencies": {
    "@chroma-core/default-embed": "^1.0.0"
  },
  "scripts": {
    "test": "find worker -name '*.test.js' -not -path '*/node_modules/*' -print0 | xargs -0 node --test",
    "test:storage": "node --test worker/db/query-engine-*.test.js",
    "test:hub-sync": "find worker/hub-sync -name '*.test.js' -print0 | xargs -0 node --test",
    "test:migrations": "node --test worker/db/migration-*.test.js worker/db/migrations.test.js"
  }
}
